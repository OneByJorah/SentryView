# RTSP-NVR-Dashboard Configuration
# Copy this file to .env and edit with your settings

# Network binding (0.0.0.0 = all interfaces)
HOST_IP=0.0.0.0

# RTSP Stream URL (replace with your NVR stream)
# Examples:
#   rtsp://admin:admin@192.168.1.10:554/stream
#   rtsp://user:password@10.0.0.50:554/live.sdp
NVR_URL=rtsp://admin:admin@192.168.1.10:554/stream

# Web UI Authentication (bcrypt hashed password recommended)
# Generate hash: python3 -c "from bcrypt import gensalt, hashpw; print(hashpw(b'your_password').decode())"
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# Recording Settings
AUDIO_THRESHOLD_DB=30
RECORDING_RETENTION_DAYS=7
MAX_RECORDINGS=10

# FFmpeg Options
FFMPEG_BUFFER_SIZE=2
FFMPEG_FPS=25
